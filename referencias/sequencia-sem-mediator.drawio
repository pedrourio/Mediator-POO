<mxfile host="app.diagrams.net">
  <diagram name="Sequencia-Sem-Mediator" id="seqDiagSemMediator01">
    <mxGraphModel dx="808" dy="471" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t-note" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontStyle=2;fontSize=12;" value="Sem Mediator: ScreenBuilder registra ActionListener em btn1 que calcula a pessoa mais próxima e chama receberMensagem() diretamente.&#xa;Não há mediador — o acoplamento e a lógica de distância estão embutidos no listener do ScreenBuilder." vertex="1">
          <mxGeometry height="50" width="660" x="60" y="0" as="geometry" />
        </mxCell>

        <!-- Lifeline: ConcretePessoa (remetente) -->
        <mxCell id="ll-rem" parent="1" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};" value="ConcretePessoa (remetente)" vertex="1">
          <mxGeometry height="420" width="180" x="60" y="80" as="geometry" />
        </mxCell>
        <mxCell id="act-rem" parent="ll-rem" style="html=1;points=[[0,0,0,0,5],[0,1,0,0,-5],[1,0,0,0,5],[1,1,0,0,-5]];perimeter=orthogonalPerimeter;outlineConnect=0;targetShapes=umlLifeline;portConstraint=eastwest;" value="" vertex="1">
          <mxGeometry height="260" width="10" x="85" y="80" as="geometry" />
        </mxCell>

        <!-- Lifeline: ScreenBuilder (ActionListener) -->
        <mxCell id="ll-sb" parent="1" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};" value="ScreenBuilder (ActionListener)" vertex="1">
          <mxGeometry height="420" width="200" x="340" y="80" as="geometry" />
        </mxCell>
        <mxCell id="act-sb" parent="ll-sb" style="html=1;points=[[0,0,0,0,5],[0,1,0,0,-5],[1,0,0,0,5],[1,1,0,0,-5]];perimeter=orthogonalPerimeter;outlineConnect=0;targetShapes=umlLifeline;portConstraint=eastwest;" value="" vertex="1">
          <mxGeometry height="160" width="10" x="95" y="118" as="geometry" />
        </mxCell>

        <!-- Lifeline: ConcretePessoa (destinatario) -->
        <mxCell id="ll-dest" parent="1" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};" value="ConcretePessoa (destinatário)" vertex="1">
          <mxGeometry height="420" width="180" x="660" y="80" as="geometry" />
        </mxCell>
        <mxCell id="act-dest" parent="ll-dest" style="html=1;points=[[0,0,0,0,5],[0,1,0,0,-5],[1,0,0,0,5],[1,1,0,0,-5]];perimeter=orthogonalPerimeter;outlineConnect=0;targetShapes=umlLifeline;portConstraint=eastwest;" value="" vertex="1">
          <mxGeometry height="60" width="10" x="85" y="178" as="geometry" />
        </mxCell>

        <!-- msg1: self-call btn1.click -->
        <mxCell id="msg1" edge="1" parent="1" source="act-rem" target="act-rem" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.02;exitDx=0;exitDy=0;" value="btn1.click → actionPerformed()">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="230" y="110" />
              <mxPoint x="230" y="130" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- msg2: actionPerformed -> ScreenBuilder listener -->
        <mxCell id="msg2" edge="1" parent="1" source="act-rem" target="act-sb" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.18;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" value="actionPerformed(e)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- msg3: receberMensagem direto -->
        <mxCell id="msg3" edge="1" parent="1" source="act-sb" target="act-dest" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" value="receberMensagem(msg)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- return dest -> sb -->
        <mxCell id="ret1" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;" value="return">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="745" y="256" as="sourcePoint" />
            <mxPoint x="445" y="256" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- return sb -> rem -->
        <mxCell id="ret2" edge="1" parent="1" source="act-sb" target="act-rem" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;exitX=0;exitY=1;exitDx=0;exitDy=0;" value="return">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
