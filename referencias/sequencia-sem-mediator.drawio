        <mxCell id="msg-ret-outra" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;" value="return">
          <mxGeometry relative="1" as="geometry">
